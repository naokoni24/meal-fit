# ===== AI（無料運用：Gemini 主軸）=====
# 未設定でもモックデータで動作します（無料・キー不要で開発可能）
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 思考トークンを無効化（コスト約1/4・約3倍速。献立提案では品質十分）
GEMINI_THINKING_BUDGET=0

# ===== レート制限（無料枠を守る）=====
RATE_LIMIT_ANON=3
RATE_LIMIT_USER=5

# ===== Unsplash（料理写真表示。未設定時は絵文字プレースホルダを表示）=====
# 無料枠: 50 req/時。https://unsplash.com/developers で取得（Access Key）
UNSPLASH_ACCESS_KEY=

# ===== Supabase（MVPの保存系で使用。縦切り段階では未使用でOK）=====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
